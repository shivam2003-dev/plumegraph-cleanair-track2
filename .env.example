# Backend-only environment variables.
# Do not expose private keys in GitHub Pages or browser JavaScript.

PLUMEGRAPH_AI_PROXY_URL=https://your-secure-backend.example.com/ai
OPENROUTER_API_KEY=replace_on_backend_only

# Client-side Google Maps keys are visible in the browser.
# If used, restrict by HTTP referrer to your GitHub Pages domain.
# For local demos only, create config.local.js with:
# window.PLUMEGRAPH_GOOGLE_MAPS_KEY = "your-restricted-browser-key";
PLUMEGRAPH_GOOGLE_MAPS_KEY=replace_with_restricted_browser_key
